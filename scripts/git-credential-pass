#!/usr/bin/env bash
# Git credential helper using pass - only serves github.com/AtunBetun
export PATH="/home/linuxbrew/.linuxbrew/bin:$PATH"
export GPG_TTY=$(tty)

[[ "$1" != "get" ]] && exit 0

host=""
while IFS='=' read -r key value; do
    [[ "$key" == "host" ]] && host="$value"
done

if [[ "$host" == "github.com" ]]; then
    password=$(/home/linuxbrew/.linuxbrew/bin/pass show github.com/AtunBetun 2>/dev/null | head -1)
    if [[ -n "$password" ]]; then
        printf 'protocol=https\nhost=github.com\nusername=AtunBetun\npassword=%s\n' "$password"
    fi
fi
