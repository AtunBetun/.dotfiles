#!/usr/bin/env zsh
set -e

if [[ -z "${1:-}" ]]; then
    echo "Missing target platform."
    echo "Usage: $0 {mac|ubuntu}"
    exit 1
fi

case "$1" in
    mac)
        STOW_FOLDERS=(ghostty mise nvim scripts sessionizer tmux zsh aerospace)
        ;;
    ubuntu)
        STOW_FOLDERS=(ghostty mise nvim personal scripts sessionizer tmux zsh)
        ;;
    al2)
        STOW_FOLDERS=(mise nvim scripts tmux zsh amazon)
        ;;
    *)
        echo "Unsupported target platform: $1"
        echo "Usage: $0 {mac|ubuntu|al2}"
        exit 1
        ;;
esac

echo "[stow] Installing profile: $1"

if [[ -z $DOTFILES ]]; then
    DOTFILES=$HOME/.dotfiles
fi

pushd "$DOTFILES" >/dev/null
for folder in $STOW_FOLDERS
do
    echo "[stow] Applying $folder"
    stow -D "$folder" || echo "[stow] No existing links to remove for $folder"
    stow "$folder"
done
popd >/dev/null

echo "[stow] Profile $1 installed"
