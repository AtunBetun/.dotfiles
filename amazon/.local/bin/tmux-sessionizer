#!/usr/bin/env zsh

export PATH="$HOME/.local/bin:$PATH"
eval "$(mise activate zsh)"
if [[ -n "$mise_bin" ]]; then
    eval "$("$mise_bin" activate zsh)"
fi

if [[ $# -eq 1 ]]; then
    selected=$1
else
    search_paths=()
    [[ -d "/workplace/$USER" ]] && search_paths+=("/workplace/$USER")
    [[ -d "$HOME/brazil-workspaces" ]] && search_paths+=("$HOME/brazil-workspaces")
    (( ${#search_paths[@]} )) || exit 0
    selected=$(find "${search_paths[@]}" -mindepth 1 -maxdepth 2 -type d 2>/dev/null | fzf --height=90% --border=sharp --prompt='Open Tmux Session > ' --preview='tree -C {}' --preview-window='45%,border-sharp')
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s "$selected_name" -c "$selected"
    exit 0
fi

if ! tmux has-session -t="$selected_name" 2> /dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
fi

tmux switch-client -t "$selected_name"
