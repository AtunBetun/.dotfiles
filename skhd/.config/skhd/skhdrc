# Mod key = Option (alt)
# i3-like bindings

# --- Launch apps ---
# Option+Enter → Terminal
alt - return : open -na kitty

# --- Switch desktops (Spaces) ---
# Option+1..9 → Switch to Space 1..9
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
# (repeat as needed)

# --- Move window to desktop ---
# Option+Shift+1..9 → Send window to Space 1..9
alt - shift - 1 : yabai -m window --space 1; yabai -m space --focus 1
alt - shift - 2 : yabai -m window --space 2; yabai -m space --focus 2
alt - shift - 3 : yabai -m window --space 2; yabai -m space --focus 3

# --- Close windows ---
alt - q : yabai -m window --close

# --- Rearrange / focus windows ---
# Move focus (hjkl like vim)
alt - h : yabai -m window --focus west
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - l : yabai -m window --focus east

# Swap windows (move current window)
alt - shift - h : yabai -m window --swap west
alt - shift - j : yabai -m window --swap south
alt - shift - k : yabai -m window --swap north
alt - shift - l : yabai -m window --swap east
