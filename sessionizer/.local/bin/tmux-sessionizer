#!/usr/bin/env zsh

export PATH="$HOME/.local/bin:$PATH"
eval "$(mise activate zsh)"

if [[ $# -eq 1 ]]; then
    selected=$1
else
    search_paths=("$HOME/work" "$HOME" "$HOME/personal")
    selected=$(find "${search_paths[@]}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | fzf --height=90% --border=sharp --prompt='Open Tmux Session > ' --preview='tree -C {}' --preview-window='45%,border-sharp')
fi

[[ -z $selected ]] && exit 0

selected_name=$(basename "$selected" | tr . _)

if [[ -z $TMUX ]] && ! pgrep tmux >/dev/null; then
    tmux new-session -s "$selected_name" -c "$selected"
    exit 0
fi

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
fi

tmux switch-client -t "$selected_name"
