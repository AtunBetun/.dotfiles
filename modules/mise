#!/usr/bin/bash
set -euo pipefail
[[ "${DEBUG:-0}" == 1 ]] && set -x
trap 'status=$?; printf "ERROR [mise] line %s: %s (exit %s)\n" "$LINENO" "$BASH_COMMAND" "$status" >&2' ERR

echo "[mise] Installing Mise"
curl https://mise.run | sh
export PATH="$HOME/.local/bin:$PATH"
echo "[mise] Installing tools from mise/.config/mise/config.toml"
MISE_GLOBAL_CONFIG_FILE=./mise/.config/mise/config.toml mise install
